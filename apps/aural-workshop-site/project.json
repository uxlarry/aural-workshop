{
  "name": "aural-workshop-site",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/aural-workshop-site/src",
  "tags": ["scope:shop"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/aural-workshop-site",
        "browser": "apps/aural-workshop-site/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/aural-workshop-site/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/aural-workshop-site/public"
          }
        ],
        "styles": ["apps/aural-workshop-site/src/styles.css"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "aural-workshop-site:build:production"
        },
        "development": {
          "buildTarget": "aural-workshop-site:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "aural-workshop-site:build"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "aural-workshop-site:build",
        "port": 4200,
        "staticFilePath": "dist/apps/aural-workshop-site",
        "spa": true
      }
    },
    "package-suite": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "/usr/local/bin/node ./tools/scripts/package-app-suite.mjs"
        ],
        "parallel": false
      }
    },
    "serve-suite": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 -m http.server 4300 --directory dist/deploy"
      }
    }
  }
}
