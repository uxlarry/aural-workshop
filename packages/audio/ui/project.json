{
  "name": "audio-ui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/audio/ui/src",
  "prefix": "audio",
  "projectType": "library",
  "metadata": {
    "license": "MIT"
  },
  "tags": ["scope:shared", "type:audio-ui"],
  "targets": {
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "packages/audio/ui/.storybook",
        "browserTarget": "audio-ui:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/audio-ui",
        "configDir": "packages/audio/ui/.storybook",
        "browserTarget": "audio-ui:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c packages/audio/ui/.storybook --url=http://localhost:4400"
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": ["build-storybook"],
      "options": {
        "buildTarget": "audio-ui:build-storybook",
        "staticFilePath": "dist/storybook/audio-ui",
        "spa": true
      },
      "configurations": {
        "ci": {
          "buildTarget": "audio-ui:build-storybook:ci"
        }
      }
    }
  }
}
